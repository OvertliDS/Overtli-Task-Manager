{
  "mcp_servers": {
    "overtli_task_manager": {
      "command": "node",
      "args": [
        "${PLUGIN_ROOT}/bin/otm-mcp.mjs"
      ],
      "env": {
        "OTM_STORAGE": "auto",
        "OTM_STATE_DIR": "${PLUGIN_DATA}/state"
      },
      "enabled": true,
      "startup_timeout_sec": 20,
      "tool_timeout_sec": 45
    }
  }
}
